# Copy to .env and adjust for local development. Production doesn't need any of these.

# Override the path where the MCP server looks for the pre-built SQLite index.
# Must be an absolute path to a file ending in .db. The server validates the path
# exists and rejects anything else.
# Only needed if you want to run the server against an index in a custom location;
# by default it auto-detects next to dist/ or src/.
# MCP_ARCA_DB_PATH=/absolute/path/to/index.db
